ent edits {
  // ── VS Code Dev Container configuration ──────────────────────────────────
  // Docs: https://containers.dev/
  //
  // Usage:
  //   1. Open this repo in VS Code.
  //   2. Install the "Dev Containers" extension (ms-vscode-remote.remote-containers).
  //   3. Press F1 → "Dev Containers: Reopen in Container".
  //
  // The container is built from the project Dockerfile and mounts the
  // workspace so all file edits are reflected on your host filesystem.
  // ─────────────────────────────────────────────────────────────────────────

  "name": "MLinCP",

  // Explicitly empty — prevents VS Code from auto-adding features such as
  // docker-in-docker, which fails on Docker Desktop for Windows/macOS.
  "features": {},

  // Build from the repo Dockerfile rather than a pre-built image.
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },

  // Mount the local workspace into the container's notebook directory.
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace/notebooks,type=bind,consistency=cached",
  "workspaceFolder": "/workspace/notebooks",

  // Forward JupyterLab so you can open it in a browser if desired.
  "forwardPorts": [8888],
  "portsAttributes": {
    "8888": {
      "label": "JupyterLab",
      "onAutoForward": "notify"
    }
  },

  // VS Code extensions installed automatically inside the container.
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-toolsai.vscode-jupyter-renderers",
        "ms-toolsai.vscode-jupyter-cell-tags"
      ],
      "settings": {
        // Point VS Code at the UV-managed virtual environment.
        "python.defaultInterpreterPath": "/opt/mlincp/.venv/bin/python",
        // Use the named kernel registered in the Dockerfile via ipykernel install.
        "jupyter.defaultKernel": "mlincp",
        "jupyter.notebookFileRoot": "/workspace/notebooks",
        "editor.formatOnSave": false
      }
    }
  },

  // Nothing extra to run after the container starts —
  // all dependencies are already installed in the image.
  "postCreateCommand": ""
}